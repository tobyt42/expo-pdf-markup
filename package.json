{
  "name": "@tobyt/expo-pdf-markup",
  "version": "0.2.2",
  "description": "An Expo module for displaying and annotating PDFs",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "lint:swift": "swiftlint lint ios/",
    "lint:kotlin": "ktlint 'android/src/**/*.kt'",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:swift": "swiftformat ios/",
    "format:swift:check": "swiftformat --lint ios/",
    "format:kotlin": "ktlint --format 'android/src/**/*.kt'",
    "format:kotlin:check": "ktlint 'android/src/**/*.kt'",
    "test": "expo-module test",
    "test:swift": "bash scripts/test-swift.sh",
    "test:kotlin": "cd example/android && ./gradlew :tobyt-expo-pdf-markup:testDebugUnitTest",
    "typecheck": "expo-module typecheck",
    "qa:ts": "export EXPO_NONINTERACTIVE=1 && npm run typecheck && npm run format && npm run lint && npm run test",
    "qa:ios": "npm run format:swift && npm run lint:swift && npm run test:swift",
    "qa:android": "npm run format:kotlin && npm run lint:kotlin && npm run test:kotlin",
    "qa": "npm run qa:ts && npm run qa:ios && npm run qa:android",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "docs": "typedoc",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "react-native",
    "expo",
    "@tobyt/expo-pdf-markup",
    "ExpoPdfMarkup"
  ],
  "repository": "https://github.com/tobyt42/expo-pdf-markup",
  "bugs": {
    "url": "https://github.com/tobyt42/expo-pdf-markup/issues"
  },
  "author": "Toby Terhoeven <toby@terhoeven.dev> (https://github.com/tobyt42)",
  "license": "MIT",
  "homepage": "https://github.com/tobyt42/expo-pdf-markup#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "expo": "^55.0.5",
    "expo-module-scripts": "^55.0.2",
    "react-native": "0.83.2",
    "react-native-web": "^0.21.2",
    "typedoc": "^0.28.17"
  },
  "jest": {
    "preset": "expo-module-scripts"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
